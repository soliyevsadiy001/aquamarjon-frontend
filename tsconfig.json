{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode (Vite делает трансформацию/бандлинг сам) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Строгость. Исходный код (см. README) на момент разбивки проходил
       tsc с офлайн-стабом типов и ~70 warning'ами (implicit any и т.п.) —
       они уже существовали в монолите. strict оставлен включённым, чтобы
       эти места было видно и можно было поправить отдельным проходом,
       а не потому что код им уже полностью соответствует. */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true

  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
